{
	"schemaVersion": 1,
	"id": "quantumpack-magic",
	"version": "${version}",
	"name": "Quantum's Magic Mod",
	"description": "This is an example description! Tell everyone what your mod is about!",
	"authors": [
		"Me!"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/quantums-magic-mod/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"quantumgoddess.magic.QuantumMagicMod"
		],
		"client": [
			"quantumgoddess.magic.QuantumMagicModClient"
		]
	},
	"mixins": [
		"quantums-magic-mod.mixins.json",
		{
			"config": "quantumpack-magic.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.14.22",
		"minecraft": "~1.20.2",
		"java": ">=17",
		"fabric-api": "*"
	},
	"suggests": {
		"another-mod": "*"
	}
}